from heapq import heappush, heappop

# Goal State
goal = [
    [1, 2, 3],
    [4, 5, 6],
    [7, 8, 0]
]

# Find blank position
def find_blank(state):
    for i in range(3):
        for j in range(3):
            if state[i][j] == 0:
                return i, j

# Manhattan Distance Heuristic
def heuristic(state):
    distance = 0
    for i in range(3):
        for j in range(3):
            value = state[i][j]
            if value != 0:
                goal_x = (value - 1) // 3
                goal_y = (value - 1) % 3
                distance += abs(i - goal_x) + abs(j - goal_y)
    return distance

# Generate neighboring states
def neighbors(state):
    x, y = find_blank(state)
    moves = [(-1,0),(1,0),(0,-1),(0,1)]
    result = []

    for dx, dy in moves:
        nx, ny = x + dx, y + dy
        if 0 <= nx < 3 and 0 <= ny < 3:
            new_state = [row[:] for row in state]
            new_state[x][y], new_state[nx][ny] = new_state[nx][ny], new_state[x][y]
            result.append(new_state)

    return result

# Convert state to tuple
def state_to_tuple(state):
    return tuple(tuple(row) for row in state)

# Print state
def print_state(state):
    for row in state:
        print(*row)
    print()

# A* Search
def astar(start):
    pq = []
    visited = set()

    heappush(pq, (heuristic(start), 0, start, []))

    while pq:
        f, g, current, path = heappop(pq)

        if current == goal:
            print("Solution Found!\n")
            for step in path + [current]:
                print_state(step)
            print("Number of Moves =", len(path))
            return

        key = state_to_tuple(current)
        if key in visited:
            continue
        visited.add(key)

        for next_state in neighbors(current):
            if state_to_tuple(next_state) not in visited:
                heappush(
                    pq,
                    (
                        g + 1 + heuristic(next_state),
                        g + 1,
                        next_state,
                        path + [current]
                    )
                )

    print("No solution found.")

# Main
print("Enter Initial State (use 0 for blank):")
start = []
for i in range(3):
    row = list(map(int, input().split()))
    start.append(row)

astar(start)
